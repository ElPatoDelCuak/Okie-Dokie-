{
  "manifest_version": 3,
  "name": "Okie-dokie!",
  "version": "2.0",
  "description": "Automatización de búsquedas en Bing (Escritorio y Móvil).",
  "permissions": [
    "scripting",
    "tabs",
    "windows",
    "storage",
    "declarativeNetRequest"
  ],
  "host_permissions": [
    "*://*.bing.com/*",
    "*://opentdb.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "128": "128.png"
  }
}
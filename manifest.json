{
  "manifest_version": 3,
  "name": "Okie-dokie!",
  "version": "1.0",
  "description": "La carli me pone como una moto.",
  "permissions": [
    "scripting",
    "tabs",
    "windows"
  ],
  "host_permissions": [
    "*://*.bing.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "icons": {
    "128": "128.png"
  }
}